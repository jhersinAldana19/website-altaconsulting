<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://script.google.com https://script.googleusercontent.com; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com https://i.ytimg.com https://img.youtube.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; frame-src 'self' https://www.google.com https://maps.google.com https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
</IfModule>

<IfModule mod_headers.c>
  # HSTS solo en HTTPS para evitar problemas en ambientes sin SSL.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonicalización: forzar HTTPS y dominio sin www (https://altaconsulting.pe)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.altaconsulting\.pe$ [NC]
  RewriteRule ^(.*)$ https://altaconsulting.pe/$1 [R=301,L]

  # Redirecciones SEO: URLs antiguas (.php) -> rutas actuales
  RewriteRule ^contacto\.php$ /contacto [R=301,L,NC]
  RewriteRule ^servicios-outsourcing-contable\.php$ /servicios/outsourcing-contable [R=301,L,NC]
  RewriteRule ^servicios-outsourcing-tributario\.php$ /servicios/outsourcing-tributario [R=301,L,NC]
  RewriteRule ^servicios-outsourcing-finanzas\.php$ /servicios/outsourcing-finanzas [R=301,L,NC]
  RewriteRule ^por-que-elegirnos\.php$ / [R=301,L,NC]
  RewriteRule ^alta-consulting-mision\.php$ /sobre-nosotros [R=301,L,NC]
  RewriteRule ^alta-consulting-vision\.php$ /sobre-nosotros [R=301,L,NC]
  RewriteRule ^videos\.php$ /recursos [R=301,L,NC]

  # Sirve archivos y carpetas existentes normalmente.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback SPA: todas las rutas del frontend van a index.html
  RewriteRule . /index.html [L]
</IfModule>
